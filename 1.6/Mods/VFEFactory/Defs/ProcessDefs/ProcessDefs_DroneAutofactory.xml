<?xml version="1.0" encoding="utf-8" ?>
<Defs>
	<PipeSystem.ProcessDef>
		<defName>VFEFactory_AssembleBattleDrone</defName>
		<label>Assemble battle drone</label>
		<labelOverride>Assemble battle drone</labelOverride>
		<description>Automatically assemble a battle drone from steel and components.</description>
		<priorityInBillList>0</priorityInBillList>
		<spawnOnInteractionCell>true</spawnOnInteractionCell>
		<autoGrabFromHoppers>true</autoGrabFromHoppers>
		<autoInputSlots>
			<li>(-2,0,2)</li>
			<li>(0,0,4)</li>
			<li>(2,0,2)</li>
			
		</autoInputSlots>
		<ticks>20000</ticks>
		<ingredients>
			<li>
				<thing>Steel</thing>
				<countNeeded>100</countNeeded>
			</li>
			<li>
				<thing>ComponentIndustrial</thing>
				<countNeeded>4</countNeeded>
			</li>
			
		</ingredients>
		<resultToDetect>VQE_BattleDrone</resultToDetect>
		<results>
			<li>
				<thing>VQE_UnfinishedDroneSpawner_BattleDrone</thing>
				<count>1</count>
			</li>
		</results>
		<isFactoryProcess>true</isFactoryProcess>
		<autoExtract>true</autoExtract>
		<onlyGrabAndOutputToFactoryHoppers>true</onlyGrabAndOutputToFactoryHoppers>
		<effecterWhenWorking>true</effecterWhenWorking>
		<effecterDef>VFEFactory_Default</effecterDef>
		<sustainerWhenWorking>true</sustainerWhenWorking>
		<sustainerDef>VFEFactory_AutomatedMachiningSustainer</sustainerDef>
		<maxOutputCount>1</maxOutputCount>
	</PipeSystem.ProcessDef>
	
