<Defs>
	<ThingDef ParentName="UnfinishedBase">
		<defName>VQE_UnfinishedDrone</defName>
		<label>unfinished drone</label>
		<description>An unfinished drone.</description>
		<statBases>
			<Flammability>0.5</Flammability>
		</statBases>
		<graphicData>
			<texPath>Things/Item/Unfinished/UnfinishedDrone</texPath>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<stuffCategories Inherit="false"/>
	</ThingDef>
	<ThingDef Abstract="true" Name="VQE_UnfinishedDroneSpawnerBase" ParentName="ResourceBase">
		<label>deployed drone</label>
		<description>An unfinished drone. This will deploy into a drone.</description>
		<graphicData>
			<graphicClass>Graphic_Single</graphicClass>
			<texPath>Things/Item/Unfinished/UnfinishedDrone</texPath>
		</graphicData>
		<statBases>
			<MaxHitPoints>60</MaxHitPoints>
			<Flammability>0.5</Flammability>
			<DeteriorationRate>1</DeteriorationRate>
			<Mass>10</Mass>
			<MarketValue>45</MarketValue>
		</statBases>
		<tickerType>Normal</tickerType>
		<tradeability>None</tradeability>
		<thingCategories>
			<li>Unfinished</li>
		</thingCategories>
		<thingSetMakerTags>
			<li>NotForGuests</li>
		</thingSetMakerTags>
		<stackLimit>1</stackLimit>
		<tradeTags>
			<li>NonContractable</li>
		</tradeTags>
	</ThingDef>
