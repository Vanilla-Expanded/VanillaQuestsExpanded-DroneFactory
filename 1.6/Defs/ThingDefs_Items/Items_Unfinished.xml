		<comps>

			 <li Class="VanillaQuestsExpandedDroneFactory.CompProperties_DroneHatcher">
				<hatcherKindDef>VQE_CleanerDrone</hatcherKindDef>
				
			</li>
		</comps>
	</ThingDef>
	<ThingDef ParentName="VQE_UnfinishedDroneSpawnerBase">
		<defName>VQE_UnfinishedDroneSpawner_HaulerDrone</defName>
		<comps>

			 <li Class="VanillaQuestsExpandedDroneFactory.CompProperties_DroneHatcher">
				<hatcherKindDef>VQE_HaulerDrone</hatcherKindDef>
				
			</li>
		</comps>
