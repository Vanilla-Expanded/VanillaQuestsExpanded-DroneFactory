<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<ThinkTreeDef>
		<defName>VQE_Drone</defName>
		<thinkRoot Class="ThinkNode_Priority">
			<subNodes>
				<li Class="ThinkNode_Subtree">
					<treeDef>Despawned</treeDef>
				</li>
				<li Class="ThinkNode_ConditionalMentalState">
					<state>VQE_DiagnosticLoop</state>
					<subNodes>
						<li Class="JobGiver_Idle" />
					</subNodes>
				</li>
				<li Class="ThinkNode_ConditionalMentalState">
					<state>VQE_Indexing</state>
					<subNodes>
						<li Class="VanillaQuestsExpandedDroneFactory.JobGiver_Indexing" />
						<li Class="VanillaQuestsExpandedDroneFactory.JobGiver_IdleFacingTarget" />
					</subNodes>
				</li>
				<li Class="ThinkNode_ConditionalMentalState">
					<state>VQE_HoardingLoop</state>
					<subNodes>
						<li Class="VanillaQuestsExpandedDroneFactory.JobGiver_HoardingLoop" />
					</subNodes>
				</li>
				<li Class="ThinkNode_ConditionalMentalState">
					<state>VQE_Hardcrash</state>
					<subNodes>
						<li Class="VanillaQuestsExpandedDroneFactory.JobGiver_Hardcrash" />
					</subNodes>
				</li>
				<li Class="ThinkNode_ConditionalMentalState">
					<state>VQE_Desync</state>
					<subNodes>
						<li Class="VanillaQuestsExpandedDroneFactory.JobGiver_WanderDesync" />
					</subNodes>
				</li>
				<li Class="ThinkNode_ConditionalMentalState">
					<state>VQE_Reboot</state>
					<subNodes>
						<li Class="JobGiver_WanderAnywhere" />
					</subNodes>
				</li>
				<li Class="ThinkNode_ConditionalMentalState">
					<state>VQE_HardwareFailure</state>
					<subNodes>
						<li Class="JobGiver_Idle" />
					</subNodes>
				</li>
				<li Class="ThinkNode_ConditionalMentalState">
					<state>VQE_SelfDecommission</state>
					<subNodes>
						<li Class="JobGiver_ExitMapRandom">
							<defaultLocomotion>Walk</defaultLocomotion>
						</li>
						<li Class="JobGiver_WanderAnywhere">
							<maxDanger>Deadly</maxDanger>
						</li>
					</subNodes>
				</li>
				<li Class="VanillaQuestsExpandedDroneFactory.ThinkNode_ConditionalRequiresTransmitter">
					<subNodes>
						<li Class="VanillaQuestsExpandedDroneFactory.JobGiver_StandIfOutOfTransmitterRange" />
					</subNodes>
				</li>

				<!-- React to close melee threat -->
				<li Class="VanillaQuestsExpandedDroneFactory.ThinkNode_ConditionalPawnKindList">
					<pawnKinds>
						<li>VQE_BattleDrone</li>
						<li>VQE_HornetDrone</li>
						<li>VQE_Protolancer</li>
						<li>VQE_RaiderDrone</li>
						<li>VQE_ShufflerDrone</li>
						<li>VQE_StingrayDrone</li>
						<li>VQE_TurretDrone</li>
					</pawnKinds>
					<subNodes>
						<li Class="JobGiver_ReactToCloseMeleeThreat" />
					</subNodes>
				</li>

				<!-- Do a queued job -->
				<li Class="ThinkNode_QueuedJob" />

				<!-- Wait if drafted -->
				<li Class="ThinkNode_ConditionalOfPlayerFaction">
					<subNodes>
						<li Class="ThinkNode_Tagger">
							<tagToGive>DraftedOrder</tagToGive>
							<subNodes>
								<li Class="JobGiver_MoveToStandable" />
								<li Class="JobGiver_Orders" />
							</subNodes>
						</li>
					</subNodes>
				</li>

				<li Class="ThinkNode_Subtree">
					<treeDef>LordDuty</treeDef>
				</li>

				<li Class="ThinkNode_ConditionalSentryDroneMode">
					<mode>Patrol</mode>
					<subNodes>
						<li Class="VanillaQuestsExpandedDroneFactory.JobGiver_SentryPatrol" />
					</subNodes>
				</li>
				<li Class="ThinkNode_ConditionalSentryDroneMode">
					<mode>Attack</mode>
					<subNodes>
						<li Class="JobGiver_AIFightEnemies">
							<targetAcquireRadius>65</targetAcquireRadius>
							<targetKeepRadius>72</targetKeepRadius>
							<needLOSToAcquireNonPawnTargets>true</needLOSToAcquireNonPawnTargets>
						</li>
						<li Class="JobGiver_AITrashColonyClose" />
						<li Class="JobGiver_AIGotoNearestHostile" />
					</subNodes>
				</li>

				<!-- Seek allowed area if outside -->
				<li Class="JobGiver_SeekAllowedArea" />

				<li Class="VanillaQuestsExpandedDroneFactory.ThinkNode_ConditionalPawnKindList">
					<pawnKinds>
						<li>VQE_CleanerDrone</li>
					</pawnKinds>
					<subNodes>
						<li Class="VanillaQuestsExpandedDroneFactory.JobGiver_DoWork">

							<workgivers>
								<li>CleanFilth</li>
							</workgivers>
						</li>
					</subNodes>
				</li>
				<li Class="VanillaQuestsExpandedDroneFactory.ThinkNode_ConditionalPawnKindList">
					<pawnKinds>
						<li>VQE_CraftingDroneKindDef</li>
					</pawnKinds>
					<subNodes>
						<li Class="VanillaQuestsExpandedDroneFactory.JobGiver_DoWork">

							<workTypes>
								<li>Crafting</li>
							</workTypes>
						</li>
					</subNodes>
				</li>
				<li Class="VanillaQuestsExpandedDroneFactory.ThinkNode_ConditionalPawnKindList">
					<pawnKinds>
						<li>VQE_HaulerDrone</li>
					</pawnKinds>
					<subNodes>
						<li Class="VanillaQuestsExpandedDroneFactory.JobGiver_DoWork">
							<workTypes>
								<li>Hauling</li>
							</workTypes>

						</li>
					</subNodes>
				</li>
				<li Class="VanillaQuestsExpandedDroneFactory.ThinkNode_ConditionalPawnKindList">
					<pawnKinds>
						<li>VQE_MinerDrone</li>
					</pawnKinds>
					<subNodes>
						<li Class="VanillaQuestsExpandedDroneFactory.JobGiver_DoWork">

							<workgivers>
								<li>Mine</li>
								<li>Drill</li>
							</workgivers>
						</li>
					</subNodes>
				</li>
				<li Class="VanillaQuestsExpandedDroneFactory.ThinkNode_ConditionalPawnKindList">
					<pawnKinds>
						<li>VQE_FarmingDrone</li>
					</pawnKinds>
					<subNodes>
						<li Class="VanillaQuestsExpandedDroneFactory.JobGiver_DoWork">

							<workgivers>
								<li>VQE_DroneGrowerHarvest</li>
								<li>VQE_DroneGrowerSow</li>
								<li>PlantsCut</li>
							</workgivers>
						</li>
					</subNodes>
				</li>
				<li Class="VanillaQuestsExpandedDroneFactory.ThinkNode_ConditionalPawnKindList">
					<pawnKinds>
						<li>VQE_FirefighterDrone</li>
					</pawnKinds>
					<subNodes>
						<li Class="VanillaQuestsExpandedDroneFactory.JobGiver_DoWork">

							<workTypes>
								<li>Firefighter</li>
							</workTypes>
						</li>
					</subNodes>
				</li>

				<li Class="ThinkNode_Tagger">
					<tagToGive>Idle</tagToGive>
					<subNodes>
						<li Class="JobGiver_WanderAnywhere">
							<maxDanger>Deadly</maxDanger>
						</li>
					</subNodes>
				</li>
				<li Class="JobGiver_IdleError" />
			</subNodes>
		</thinkRoot>
	</ThinkTreeDef>
</Defs>