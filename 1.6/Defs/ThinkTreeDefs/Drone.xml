<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<ThinkTreeDef>
		<defName>VQE_Drone</defName>
		<thinkRoot Class="ThinkNode_Priority">
			<subNodes>
				<li Class="ThinkNode_Subtree">
					<treeDef>Despawned</treeDef>
				</li>
				<li Class="ThinkNode_ConditionalMentalState">
					<state>VQE_DiagnosticLoop</state>
					<subNodes>
						<li Class="JobGiver_Idle" />
					</subNodes>
				</li>
				<li Class="ThinkNode_ConditionalMentalState">
					<state>VQE_HoardingLoop</state>
					<subNodes>
						<li Class="VanillaQuestsExpandedDroneFactory.JobGiver_HoardingLoop" />
					</subNodes>
				</li>
				<li Class="ThinkNode_ConditionalMentalState">
					<state>VQE_Hardcrash</state>
					<subNodes>
						<li Class="VanillaQuestsExpandedDroneFactory.JobGiver_Hardcrash" />
					</subNodes>
				</li>
				<li Class="ThinkNode_ConditionalMentalState">
					<state>VQE_Desync</state>
					<subNodes>
						<li Class="VanillaQuestsExpandedDroneFactory.JobGiver_WanderDesync" />
					</subNodes>
				</li>
				<li Class="ThinkNode_ConditionalMentalState">
					<state>VQE_Reboot</state>
					<subNodes>
						<li Class="JobGiver_WanderAnywhere" />
					</subNodes>
				</li>
				<li Class="ThinkNode_ConditionalMentalState">
					<state>VQE_HardwareFailure</state>
					<subNodes>
						<li Class="JobGiver_Idle" />
					</subNodes>
				</li>
				<li Class="ThinkNode_ConditionalMentalState">
					<state>VQE_SelfDecommission</state>
					<subNodes>
						<li Class="JobGiver_ExitMapRandom">
							<defaultLocomotion>Walk</defaultLocomotion>
						</li>
						<li Class="JobGiver_WanderAnywhere">
							<maxDanger>Deadly</maxDanger>
						</li>
					</subNodes>
				</li>
				<li Class="VanillaQuestsExpandedDroneFactory.JobGiver_StandIfOutOfTransmitterRange" />
				<!-- React to close melee threat -->
				<li Class="JobGiver_ReactToCloseMeleeThreat" />
				<!-- Do a queued job -->
				<li Class="ThinkNode_QueuedJob" />
				<!-- Wait if drafted -->
				<li Class="ThinkNode_ConditionalOfPlayerFaction">
					<subNodes>
						<li Class="ThinkNode_Tagger">
							<tagToGive>DraftedOrder</tagToGive>
							<subNodes>
								<li Class="JobGiver_MoveToStandable" />
								<li Class="JobGiver_Orders" />
							</subNodes>
						</li>
					</subNodes>
				</li>
				<li Class="ThinkNode_Subtree">
					<treeDef>LordDuty</treeDef>
				</li>
				<li Class="VanillaQuestsExpandedDroneFactory.ThinkNode_ConditionalPawnKindList">
					<pawnKinds>
						<li>VQE_CleanerDrone</li>
					</pawnKinds>
					<subNodes>
						<li Class="VanillaQuestsExpandedDroneFactory.JobGiver_DoWork">
							
							<workgivers>
								<li>CleanFilth</li>
							</workgivers>
						</li>
					</subNodes>
				</li>
				<li Class="VanillaQuestsExpandedDroneFactory.ThinkNode_ConditionalPawnKindList">
					<pawnKinds>
						<li>VQE_HaulerDrone</li>
					</pawnKinds>
					<subNodes>
						<li Class="VanillaQuestsExpandedDroneFactory.JobGiver_DoWork">
							<workTypes>
								<li>Hauling</li>
							</workTypes>
							
						</li>
					</subNodes>
				</li>
				<li Class="VanillaQuestsExpandedDroneFactory.ThinkNode_ConditionalPawnKindList">
					<pawnKinds>
						<li>VQE_MinerDrone</li>
					</pawnKinds>
					<subNodes>
						<li Class="VanillaQuestsExpandedDroneFactory.JobGiver_DoWork">
							
							<workgivers>
								<li>Mine</li>
							</workgivers>
						</li>
					</subNodes>
				</li>
				<li Class="VanillaQuestsExpandedDroneFactory.ThinkNode_ConditionalPawnKindList">
					<pawnKinds>
						<li>VQE_FarmingDrone</li>
					</pawnKinds>
					<subNodes>
						<li Class="VanillaQuestsExpandedDroneFactory.JobGiver_DoWork">
							
							<workgivers>
								<li>VQE_DroneGrowerHarvest</li>
								<li>VQE_DroneGrowerSow</li>
								<li>PlantsCut</li>
							</workgivers>
						</li>
					</subNodes>
				</li>
				<li Class="VanillaQuestsExpandedDroneFactory.ThinkNode_ConditionalPawnKindList">
					<pawnKinds>
						<li>VQE_FirefighterDrone</li>
					</pawnKinds>
					<subNodes>
						<li Class="VanillaQuestsExpandedDroneFactory.JobGiver_DoWork">
							
							<workTypes>
								<li>Firefighter</li>
							</workTypes>
						</li>
					</subNodes>
				</li>
				<li Class="ThinkNode_ConditionalPlayerControlledMech">
					<invert>true</invert>
					<subNodes>
						<li Class="JobGiver_AIFightEnemies">
							<targetAcquireRadius>30</targetAcquireRadius>
							<targetKeepRadius>35</targetKeepRadius>
						</li>
					</subNodes>
				</li>
				<li Class="ThinkNode_ConditionalPlayerControlledMech">
					<subNodes>
						<li Class="ThinkNode_Tagger">
							<tagToGive>Idle</tagToGive>
							<subNodes>
								<li Class="JobGiver_WanderColony">
									<maxDanger>None</maxDanger>
								</li>
							</subNodes>
						</li>
					</subNodes>
				</li>
				<li Class="ThinkNode_Tagger">
					<tagToGive>Idle</tagToGive>
					<subNodes>
						<li Class="JobGiver_WanderAnywhere">
							<maxDanger>Deadly</maxDanger>
						</li>
					</subNodes>
				</li>
				<li Class="JobGiver_IdleError" />
			</subNodes>
		</thinkRoot>
	</ThinkTreeDef>
</Defs>