<?xml version="1.0" encoding="utf-8" ?>
<Defs>
    <HediffDef>
        <defName>VQE_SensorLag</defName>
        <label>sensor lag</label>
        <description>Sensor lag causing capacity penalties.</description>
        <stages>
            <li>
                <capMods>
                    <li>
                        <capacity>Moving</capacity>
                        <postFactor>0.75</postFactor>
                    </li>
                    <li>
                        <capacity>Manipulation</capacity>
                        <postFactor>0.75</postFactor>
                    </li>
                    <li>
                        <capacity>Sight</capacity>
                        <postFactor>0.75</postFactor>
                    </li>
                    <li>
                        <capacity>BloodFiltration</capacity>
                        <postFactor>0.75</postFactor>
                    </li>
                </capMods>
            </li>
        </stages>
    </HediffDef>

    <HediffDef>
        <defName>VQE_Overclock</defName>
        <label>overclocked</label>
        <description>Performance increased at the cost of lifespan.</description>
        <stages>
            <li>
                <statFactors>
                    <WorkSpeedGlobal>2</WorkSpeedGlobal>
                    <MoveSpeed>2</MoveSpeed>
                </statFactors>
            </li>
        </stages>
    </HediffDef>
</Defs>
