<Defs>
	<HediffDef>
		<defName>VQE_Broadcaster_WorkMode</defName>
		<label>work mode</label>
		<defaultLabelColor>(0.52, 1, 0.95)</defaultLabelColor>
		<description>Autobroadcaster is playing energetic music that makes everyone work a little bit harder.</description>
		<allowMothballIfLowPriorityWorldPawn>true</allowMothballIfLowPriorityWorldPawn>
		<hediffClass>HediffWithComps</hediffClass>
		<comps>
			<li Class="HediffCompProperties_DisappearsOnDeath"/>
			<li Class="VEF.AnimalBehaviours.HediffCompProperties_GiveHediffsInRangeExpanded">
				<range>9.9</range>
				<mote>VQE_Ability_Mote</mote>
				<hideMoteWhenNotDrafted>false</hideMoteWhenNotDrafted>
				<targetingParameters>
					<canTargetBuildings>false</canTargetBuildings>
					<canTargetAnimals>false</canTargetAnimals>
					<canTargetMechs>false</canTargetMechs>
					<onlyTargetColonists>true</onlyTargetColonists>
				</targetingParameters>
				<hediff>VQE_Broadcaster_WorkMode_Buff</hediff>
				<needLOS>true</needLOS>
			</li>
		</comps>
		<isBad>false</isBad>
	</HediffDef>
