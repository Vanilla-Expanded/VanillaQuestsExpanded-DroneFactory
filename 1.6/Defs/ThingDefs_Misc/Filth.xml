<?xml version="1.0" encoding="utf-8" ?>
<Defs>
    <ThingDef ParentName="BaseFilth">
        <defName>VQE_MachiningFluid</defName>
        <label>machining fluid smear</label>
        <description>A smear of flammable machining fluid.</description>
        <thingClass>LiquidFuel</thingClass>
        <useHitPoints>true</useHitPoints>
        <tickerType>Normal</tickerType>
        <statBases>
            <Beauty>-10</Beauty>
            <Cleanliness>-10</Cleanliness>
            <MaxHitPoints>150</MaxHitPoints>
            <Flammability>1.5</Flammability>
        </statBases>
        <graphicData>
            <texPath>Things/Filth/CrawlSmear</texPath>
            <graphicClass>Graphic_ClusterTight</graphicClass>
            <drawSize>0.9</drawSize>
            <color>(10, 10, 50, 165)</color>
        </graphicData>
        <filth>
            <ignoreFilthMultiplierStat>true</ignoreFilthMultiplierStat>
            <disappearsInDays>35~45</disappearsInDays>
            <rainWashes>true</rainWashes>
            <cleaningWorkToReduceThickness>180</cleaningWorkToReduceThickness>
            <canFilthAttach>true</canFilthAttach>
            <maxThickness>1</maxThickness>
            <cleaningSound>Interact_CleanFilth_Fluid</cleaningSound>
        </filth>
    </ThingDef>
</Defs>
