<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<ThingDef ParentName="VQE_BaseDrone">
		<defName>VQE_AutobroadcasterDrone</defName>
		<label>autobroadcaster drone</label>
		<description>An automated utility drone designed to support colony productivity and morale by broadcasting specific audio signals. It can switch between different modes to boost work speed, improve colonist mood, or even lower prisoner resistance within its effective radius.\n\nDrones have a limited lifespan and will begin malfunctioning as they near end-of-life, but can use standby mode to slow component degradation. They require connection to a powered drone transmitter to function.</description>
		
		<statBases>
			<MoveSpeed>2.1</MoveSpeed>
			<ArmorRating_Blunt>0.1</ArmorRating_Blunt>
			<ArmorRating_Sharp>0.1</ArmorRating_Sharp>
			<ArmorRating_Heat>1</ArmorRating_Heat>
			
		</statBases>
		<race>
		
			<thinkTreeMain>VQE_Drone</thinkTreeMain>
			<baseHealthScale>1</baseHealthScale>
			<baseBodySize>0.3</baseBodySize>
			<body>VQE_DroneWithWheels</body>
			<hasCorpse>true</hasCorpse>
			<lifeStageAges>
				<li>
					<def>MechanoidFullyFormed</def>
					<minAge>0</minAge>
					<soundWounded>VQE_Drone_Light_Wounded</soundWounded>
					<soundDeath>VQE_Drone_Death</soundDeath>
					<soundCall>VQE_Drone_Light_Call</soundCall>
				</li>
			</lifeStageAges>
		</race>
		<tools>
			<li>
				<label>shell spike</label>
				<capacities>
					<li>Stab</li>
				</capacities>
				<power>1</power>
				<cooldownTime>3</cooldownTime>
				<linkedBodyPartsGroup>VQE_SpikedShellAttackTool</linkedBodyPartsGroup>
				<ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
			</li>
		</tools>
		<comps>
			<li Class="VanillaQuestsExpandedDroneFactory.CompProperties_Autobroadcaster">
				
			</li>
		
		</comps>
		<butcherProducts>
			<Steel>55</Steel>
			<ComponentIndustrial>6</ComponentIndustrial>
		</butcherProducts>
		
	</ThingDef>
	<PawnKindDef ParentName="VQE_BaseDroneKindNonCombat">
		<defName>VQE_AutobroadcasterDrone</defName>
		<label>autobroadcaster drone</label>
		<labelPlural>autobroadcaster drones</labelPlural>
		<race>VQE_AutobroadcasterDrone</race>
		<combatPower>10</combatPower>
		<canOpenAnyDoor>true</canOpenAnyDoor>
		<lifeStages>
			<li>
				<bodyGraphicData>
					<texPath>Things/Drones/PropagandaDrone/PropagandaDrone</texPath>
					<drawSize>1.45</drawSize>
				</bodyGraphicData>
			</li>
		</lifeStages>
		<canOpenDoors>true</canOpenDoors>
		
	</PawnKindDef>
</Defs>