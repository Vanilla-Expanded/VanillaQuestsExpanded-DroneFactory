<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<ThingDef ParentName="VQE_BaseDrone_NoTransmitterRequirement">
		<defName>VQE_RaiderDrone</defName>
		<label>raider drone</label>
		<description>An automated drone designed for close-quarters raiding and heavy suppression. Equipped with a high-capacity rattlegun, its slow, heavily armored frame allows it to stand its ground and saturate an area with continuous fire, suppressing enemy positions.\n\nDrones have a limited lifespan and will begin malfunctioning as they near end-of-life, but can use standby mode to slow component degradation. Unlike other drones, raider drones don’t require connection to drone transmitters.</description>
		<descriptionHyperlinks>
			<ThingDef>VQE_Gun_Rattlegun</ThingDef>
		</descriptionHyperlinks>
		<statBases>
			<MoveSpeed>2.9</MoveSpeed>
			<ArmorRating_Blunt>0.2</ArmorRating_Blunt>
			<ArmorRating_Sharp>0.55</ArmorRating_Sharp>
			<VQE_LifespanYears>2</VQE_LifespanYears>
		</statBases>
		<race>
			<thinkTreeMain>VQE_Drone</thinkTreeMain>
			<baseHealthScale>1.25</baseHealthScale>
			<baseBodySize>1.25</baseBodySize>
			<body>VQE_DroneWithTreads</body>
			<hasCorpse>true</hasCorpse>
			<lifeStageAges>
				<li>
					<def>MechanoidFullyFormed</def>
					<minAge>0</minAge>
					<soundWounded>VQE_Drone_Medium_Wounded</soundWounded>
					<soundDeath>VQE_Drone_Death</soundDeath>
					<soundCall>VQE_Drone_Medium_Call</soundCall>
				</li>
			</lifeStageAges>
		</race>
		<tools>
			<li>
				<label>shell spike</label>
				<capacities>
					<li>Stab</li>
				</capacities>
				<power>6</power>
				<cooldownTime>2.6</cooldownTime>
				<linkedBodyPartsGroup>VQE_SpikedShellAttackTool</linkedBodyPartsGroup>
				<ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
			</li>
		</tools>
		<costList>
			<Steel>280</Steel>
			<ComponentIndustrial>10</ComponentIndustrial>
			<VQE_DroneCore>1</VQE_DroneCore>
		</costList>
		<butcherProducts>
			<Steel>20</Steel>		
		</butcherProducts>
		<comps>
			<li>
				<compClass>CompSentryDrone</compClass>
			</li>
		</comps>
	</ThingDef>
	<PawnKindDef ParentName="VQE_BaseDroneKind">
		<defName>VQE_RaiderDrone</defName>
		<label>raider drone</label>
		<labelPlural>raider drones</labelPlural>
		<race>VQE_RaiderDrone</race>
		<combatPower>140</combatPower>
		<canOpenAnyDoor>true</canOpenAnyDoor>
		<lifeStages>
			<li>
				<bodyGraphicData>
					<texPath>Things/Drones/RaiderDrone/RaiderDrone</texPath>
					<drawSize>2</drawSize>
				</bodyGraphicData>
			</li>
		</lifeStages>
		<canOpenDoors>true</canOpenDoors>
		<weaponTags>
			<li>VQE_Gun_Rattlegun</li>
		</weaponTags>
	</PawnKindDef>
</Defs>