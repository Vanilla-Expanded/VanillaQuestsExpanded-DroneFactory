<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<ThingDef ParentName="VQE_BaseDrone_RequiresTransmitter">
		<defName>VQE_TurretDrone</defName>
		<label>turret drone</label>
		<description>An automated military drone designed for static defense. It is equipped with a twin-barrel turret mounted on a heavily armored, treaded platform. Though slow, it can reposition itself when needed.\n\nDrones have a limited lifespan and will begin malfunctioning as they near end-of-life, but can use standby mode to slow component degradation. They require connection to a powered drone transmitter to function.</description>
		<descriptionHyperlinks>
			<ThingDef>VQE_Gun_DroneTurret</ThingDef>
		</descriptionHyperlinks>
		<statBases>
			<MoveSpeed>1.8</MoveSpeed>
			<ArmorRating_Blunt>0.15</ArmorRating_Blunt>
			<ArmorRating_Sharp>0.4</ArmorRating_Sharp>
			<VQE_LifespanYears>5</VQE_LifespanYears>
		</statBases>
		<race>
			<thinkTreeMain>VQE_Drone</thinkTreeMain>
			<baseHealthScale>1</baseHealthScale>
			<baseBodySize>0.7</baseBodySize>
			<body>VQE_DroneWithTreads</body>
			<hasCorpse>true</hasCorpse>
			<lifeStageAges>
				<li>
					<def>MechanoidFullyFormed</def>
					<minAge>0</minAge>
					<soundWounded>VQE_Drone_Medium_Wounded</soundWounded>
					<soundDeath>VQE_Drone_Death</soundDeath>
					<soundCall>VQE_Drone_Medium_Call</soundCall>
				</li>
			</lifeStageAges>
		</race>
		<tools>
			<li>
				<label>shell spike</label>
				<capacities>
					<li>Stab</li>
				</capacities>
				<power>6</power>
				<cooldownTime>2.6</cooldownTime>
				<linkedBodyPartsGroup>VQE_SpikedShellAttackTool</linkedBodyPartsGroup>
				<ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
			</li>
		</tools>
		<costList>
			<Steel>120</Steel>
			<ComponentIndustrial>7</ComponentIndustrial>
		</costList>
		<butcherProducts>
			<Steel>15</Steel>		
		</butcherProducts>
		<comps>
			<li>
				<compClass>CompSentryDrone</compClass>
			</li>
		</comps>
	</ThingDef>
	<PawnKindDef ParentName="VQE_BaseDroneKind">
		<defName>VQE_TurretDrone</defName>
		<label>turret drone</label>
		<labelPlural>turret drones</labelPlural>
		<race>VQE_TurretDrone</race>
		<combatPower>60</combatPower>
		<canOpenAnyDoor>true</canOpenAnyDoor>
		<lifeStages>
			<li>
				<bodyGraphicData>
					<texPath>Things/Drones/TurretDrone/TurretDrone</texPath>
					<drawSize>1.45</drawSize>
				</bodyGraphicData>
			</li>
		</lifeStages>
		<canOpenDoors>true</canOpenDoors>
		<weaponTags>
			<li>VQE_Gun_DroneTurret</li>
		</weaponTags>
	</PawnKindDef>
</Defs>