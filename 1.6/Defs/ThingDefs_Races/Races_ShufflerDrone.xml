<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<ThingDef ParentName="VQE_BaseDrone_NoTransmitterRequirement">
		<defName>VQE_ShufflerDrone</defName>
		<label>shuffler drone</label>
		<description>A broken, decommissioned sentry drone. Its fried sensors and failing components cause it to shuffle aimlessly. Despite its derelict state, it will attack any tagrets it sees. Upon taking severe damage, its chassis splits into two smaller, relentless attacking drone units.</description>
		<statBases>
			<MoveSpeed>2</MoveSpeed>
			<ArmorRating_Blunt>0.15</ArmorRating_Blunt>
			<ArmorRating_Sharp>0.45</ArmorRating_Sharp>
			<VQE_LifespanYears>2500</VQE_LifespanYears>
		</statBases>
		<race>
			<thinkTreeMain>VQE_Drone</thinkTreeMain>
			<baseHealthScale>1.3</baseHealthScale>
			<baseBodySize>1</baseBodySize>
			<body>VQE_DroneWithTreads</body>
			<hasCorpse>true</hasCorpse>
			<lifeStageAges>
				<li>
					<def>MechanoidFullyFormed</def>
					<minAge>0</minAge>
					<soundWounded>VQE_Drone_Medium_Wounded</soundWounded>
					<soundDeath>VQE_Drone_Death</soundDeath>
					<soundCall>VQE_Drone_Medium_Call</soundCall>
				</li>
			</lifeStageAges>
			<deathAction Class="VEF.AnimalBehaviours.DeathActionProperties_DivideAndCreateFilth">
				<dividePawnKindOptions>
					<li>VQE_DriverDrone</li>
					<li>VQE_CrawlerDrone</li>
				</dividePawnKindOptions>
				<filthCreated>Filth_MachineBits</filthCreated>
				<filthCountRange>3~5</filthCountRange>
				<sound>VQE_Drone_Medium_Wounded</sound>
			</deathAction>
		</race>
		<tools>
			<li>
				<label>shell spike</label>
				<capacities>
					<li>Stab</li>
				</capacities>
				<power>6</power>
				<cooldownTime>2.6</cooldownTime>
				<linkedBodyPartsGroup>VQE_SpikedShellAttackTool</linkedBodyPartsGroup>
				<ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
			</li>
		</tools>
		<comps>
			<li>
				<compClass>CompSentryDrone</compClass>
			</li>
		</comps>
	</ThingDef>
	<PawnKindDef ParentName="VQE_BaseDroneKind">
		<defName>VQE_ShufflerDrone</defName>
		<label>shuffler drone</label>
		<labelPlural>shuffler drones</labelPlural>
		<race>VQE_ShufflerDrone</race>
		<combatPower>45</combatPower>
		<canOpenAnyDoor>true</canOpenAnyDoor>
		<lifeStages>
			<li>
				<bodyGraphicData>
					<texPath>Things/Drones/Shuffler/DroneShuffler</texPath>
					<drawSize>1.45</drawSize>
				</bodyGraphicData>
			</li>
		</lifeStages>
		<canOpenDoors>true</canOpenDoors>
	</PawnKindDef>

