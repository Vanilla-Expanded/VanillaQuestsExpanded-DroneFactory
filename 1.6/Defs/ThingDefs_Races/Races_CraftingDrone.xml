<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<ThingDef ParentName="VQE_BaseDrone">
		<defName>VQE_CraftingDrone</defName>
		<label>crafting drone</label>
		<description>An automated drone specialized in crafting. It periodically undergoes a special indexing operation, after which it produces a drone core that can be decoded to permanently unlock new drone schematics.\n\nDrones have a limited lifespan and will begin malfunctioning as they near end-of-life, but can use standby mode to slow component degradation. Unlike other drones, crafting drones don’t require connection to drone transmitters.</description>
		
		<statBases>
			<MoveSpeed>3.6</MoveSpeed>
			<ArmorRating_Blunt>0.1</ArmorRating_Blunt>
			<ArmorRating_Sharp>0.25</ArmorRating_Sharp>
			<WorkSpeedGlobal>0.5</WorkSpeedGlobal>
			<VQE_LifespanYears>10</VQE_LifespanYears>
		</statBases>
		<race>
			
			<thinkTreeMain>VQE_Drone</thinkTreeMain>
			<baseHealthScale>1.2</baseHealthScale>
			<baseBodySize>1.2</baseBodySize>
			<body>VQE_DroneWithLegs</body>
			<hasCorpse>true</hasCorpse>
			<lifeStageAges>
				<li>
					<def>MechanoidFullyFormed</def>
					<minAge>0</minAge>
					<soundWounded>VQE_Drone_Medium_Wounded</soundWounded>
					<soundDeath>VQE_Drone_Death</soundDeath>
					<soundCall>VQE_Drone_Medium_Call</soundCall>
				</li>
			</lifeStageAges>
		</race>
		<tools>
			<li>
				<label>shell spike</label>
				<capacities>
					<li>Stab</li>
				</capacities>
				<power>1</power>
				<cooldownTime>3</cooldownTime>
				<linkedBodyPartsGroup>VQE_SpikedShellAttackTool</linkedBodyPartsGroup>
				<ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
			</li>
		</tools>
		<butcherProducts>
			<Steel>100</Steel>
			<ComponentIndustrial>12</ComponentIndustrial>
		</butcherProducts>
		
	</ThingDef>
	<PawnKindDef ParentName="VQE_BaseDroneKindNonCombat">
		<defName>VQE_CraftingDroneKindDef</defName>
		<label>crafting drone</label>
		<labelPlural>crafting drones</labelPlural>
		<race>VQE_CraftingDrone</race>
		<combatPower>10</combatPower>
		<canOpenAnyDoor>true</canOpenAnyDoor>
		<lifeStages>
			<li>
				<bodyGraphicData>
					<texPath>Things/Drones/CraftingDrone/CraftingDrone</texPath>
					<drawSize>2</drawSize>
				</bodyGraphicData>
			</li>
		</lifeStages>
		<canOpenDoors>true</canOpenDoors>
		
	</PawnKindDef>
</Defs>