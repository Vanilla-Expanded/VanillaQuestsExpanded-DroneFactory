<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<ThingDef ParentName="VQE_BaseDrone_NoTransmitterRequirement">
		<defName>VQE_PackDrone</defName>
		<label>pack drone</label>
		<description>An automated utility drone designed primarily for heavy hauling and caravan support. Its large frame and high carrying capacity allow it to transport bulk resources in a caravan.\n\nDrones have a limited lifespan and will begin malfunctioning as they near end-of-life, but can use standby mode to slow component degradation. Unlike other drones, pack drones don’t require connection to drone transmitters.</description>
		
		<statBases>
			<MoveSpeed>3</MoveSpeed>
			<ArmorRating_Blunt>0.05</ArmorRating_Blunt>
			<ArmorRating_Sharp>0.1</ArmorRating_Sharp>
			<ArmorRating_Heat>1</ArmorRating_Heat>
			<VQE_LifespanYears>2</VQE_LifespanYears>
			<VEF_MassCarryCapacity>168</VEF_MassCarryCapacity>
		</statBases>
		<race>
			<packAnimal>true</packAnimal>
			<renderTree>VQE_PackDrone</renderTree>
			<thinkTreeMain>VQE_Drone</thinkTreeMain>
			<baseHealthScale>1.2</baseHealthScale>
			<baseBodySize>1.2</baseBodySize>
			<body>VQE_DroneWithTreads</body>
			<hasCorpse>true</hasCorpse>
			<lifeStageAges>
				<li>
					<def>MechanoidFullyFormed</def>
					<minAge>0</minAge>
					<soundWounded>VQE_Drone_Medium_Wounded</soundWounded>
					<soundDeath>VQE_Drone_Death</soundDeath>
					<soundCall>VQE_Drone_Medium_Call</soundCall>
				</li>
			</lifeStageAges>
		</race>
		<tools>
			<li>
				<label>shell spike</label>
				<capacities>
					<li>Stab</li>
				</capacities>
				<power>1</power>
				<cooldownTime>3</cooldownTime>
				<linkedBodyPartsGroup>VQE_SpikedShellAttackTool</linkedBodyPartsGroup>
				<ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
			</li>
		</tools>
		<butcherProducts>
			<Steel>200</Steel>
			<ComponentIndustrial>6</ComponentIndustrial>
		</butcherProducts>
		
	</ThingDef>
	<PawnKindDef ParentName="VQE_BaseDroneKindNonCombat">
		<defName>VQE_PackDrone</defName>
		<label>pack drone</label>
		<labelPlural>pack drones</labelPlural>
		<race>VQE_PackDrone</race>
		<combatPower>10</combatPower>
		<canOpenAnyDoor>true</canOpenAnyDoor>
		<lifeStages>
			<li>
				<bodyGraphicData>
					<texPath>Things/Drones/PackDrone/PackDrone</texPath>
					<drawSize>2</drawSize>
				</bodyGraphicData>
			</li>
		</lifeStages>
		<canOpenDoors>true</canOpenDoors>
		
	</PawnKindDef>
</Defs>