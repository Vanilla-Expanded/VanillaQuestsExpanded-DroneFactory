<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<ThingDef ParentName="VQE_BaseDrone">
		<defName>VQE_HaulerDrone</defName>
		<label>hauler drone</label>
		<description>An automated utility drone. It continuously patrols an area, looking for items that need to be hauled to stockpiles. Once an item is found, it will diligently transport it to the designated storage location.\n\nDrones have a limited lifespan and will begin malfunctioning as they near end-of-life, but can use standby mode to slow component degradation. They require connection to a powered drone transmitter to function.</description>
		
		<statBases>
			<MoveSpeed>2.2</MoveSpeed>
			<ArmorRating_Blunt>0.05</ArmorRating_Blunt>
			<ArmorRating_Sharp>0.1</ArmorRating_Sharp>
			<ArmorRating_Heat>1</ArmorRating_Heat>
			<VQE_LifespanYears>4</VQE_LifespanYears>
		</statBases>
		<race>
			
			<thinkTreeMain>VQE_Drone</thinkTreeMain>
			<baseHealthScale>1</baseHealthScale>
			<baseBodySize>0.7</baseBodySize>
			<body>VQE_DroneWithTreads</body>
			<hasCorpse>true</hasCorpse>
			<lifeStageAges>
				<li>
					<def>MechanoidFullyFormed</def>
					<minAge>0</minAge>
					<soundWounded>VQE_Drone_Light_Wounded</soundWounded>
					<soundDeath>VQE_Drone_Death</soundDeath>
					<soundCall>VQE_Drone_Light_Call</soundCall>
				</li>
			</lifeStageAges>
		</race>
		<tools>
			<li>
				<label>shell spike</label>
				<capacities>
					<li>Stab</li>
				</capacities>
				<power>1</power>
				<cooldownTime>3</cooldownTime>
				<linkedBodyPartsGroup>VQE_SpikedShellAttackTool</linkedBodyPartsGroup>
				<ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
			</li>
		</tools>
		<butcherProducts>
			<Steel>50</Steel>
			<ComponentIndustrial>3</ComponentIndustrial>
		</butcherProducts>
		
	</ThingDef>
	<PawnKindDef ParentName="VQE_BaseDroneKindNonCombat">
		<defName>VQE_HaulerDrone</defName>
		<label>hauler drone</label>
		<labelPlural>hauler drones</labelPlural>
		<race>VQE_HaulerDrone</race>
		<combatPower>10</combatPower>
		<canOpenAnyDoor>true</canOpenAnyDoor>
		<lifeStages>
			<li>
				<bodyGraphicData>
					<texPath>Things/Drones/HaulerDrone/HaulerDrone</texPath>
					<drawSize>1.45</drawSize>
				</bodyGraphicData>
			</li>
		</lifeStages>
		<canOpenDoors>true</canOpenDoors>
		
	</PawnKindDef>
</Defs>