<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<ThingDef ParentName="VQE_BaseDrone_RequiresTransmitter">
		<defName>VQE_BattleDrone</defName>
		<label>battle drone</label>
		<description>An automated battle drone. It continuously patrols an area, looking for intruders. Once an intruder is found, it will relentlessly attack with a small stubgun.\n\nDrones have a limited lifespan and will begin malfunctioning as they near end-of-life, but can use standby mode to slow component degradation. They require connection to a powered drone transmitter to function.</description>
		<descriptionHyperlinks>
			<ThingDef>VQE_Gun_Stubgun</ThingDef>
		</descriptionHyperlinks>
		<statBases>
			<MoveSpeed>2.9</MoveSpeed>
			<ArmorRating_Blunt>0.2</ArmorRating_Blunt>
			<ArmorRating_Sharp>0.1</ArmorRating_Sharp>
			<VQE_LifespanYears>5</VQE_LifespanYears>
		</statBases>
		<race>
			<thinkTreeMain>VQE_Drone</thinkTreeMain>
			<baseHealthScale>1</baseHealthScale>
			<baseBodySize>1</baseBodySize>
			<body>VQE_DroneWithSingleWheel</body>
			<hasCorpse>true</hasCorpse>
			<lifeStageAges>
				<li>
					<def>MechanoidFullyFormed</def>
					<minAge>0</minAge>
					<soundWounded>VQE_Drone_Medium_Wounded</soundWounded>
					<soundDeath>VQE_Drone_Death</soundDeath>
					<soundCall>VQE_Drone_Medium_Call</soundCall>
				</li>
			</lifeStageAges>
		</race>
		<tools>
			<li>
				<label>shell spike</label>
				<capacities>
					<li>Stab</li>
				</capacities>
				<power>6</power>
				<cooldownTime>2.6</cooldownTime>
				<linkedBodyPartsGroup>VQE_SpikedShellAttackTool</linkedBodyPartsGroup>
				<ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
			</li>
		</tools>
		<costList>
			<Steel>100</Steel>
			<ComponentIndustrial>4</ComponentIndustrial>
		</costList>
		<butcherProducts>
			<Steel>15</Steel>		
		</butcherProducts>
		<comps>
			<li>
				<compClass>CompSentryDrone</compClass>
			</li>
		</comps>
	</ThingDef>
	<PawnKindDef ParentName="VQE_BaseDroneKind">
		<defName>VQE_BattleDrone</defName>
		<label>battle drone</label>
		<labelPlural>battle drones</labelPlural>
		<race>VQE_BattleDrone</race>
		<combatPower>35</combatPower>
		<canOpenAnyDoor>true</canOpenAnyDoor>
		<lifeStages>
			<li>
				<bodyGraphicData>
					<texPath>Things/Drones/BattleDrone/BattleDrone</texPath>
					<drawSize>1.45</drawSize>
				</bodyGraphicData>
			</li>
		</lifeStages>
		<canOpenDoors>true</canOpenDoors>
		<weaponTags>
			<li>VQE_Gun_Stubgun</li>
		</weaponTags>
	</PawnKindDef>
</Defs>