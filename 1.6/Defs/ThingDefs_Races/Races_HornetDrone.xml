<?xml version="1.0" encoding="utf-8"?>
<Defs>
	<ThingDef ParentName="VQE_BaseDrone_RequiresTransmitter">
		<defName>VQE_HornetDrone</defName>
		<label>hornet drone</label>
		<description>An automated military drone for close-range defense and combat support. The drone is capable of piercing an enemy repeatedly with a long, hardened stinger. While it doesn’t carry the same paralytic as wasp drones, it’s capable of piercing heavy armor and dealing significant damage, while its heavy-duty armor plating allows it to withstand a lot of damage.\n\nDrones have a limited lifespan and will begin malfunctioning as they near end-of-life, but can use standby mode to slow component degradation. They require connection to a powered drone transmitter to function.</description>
		
		<statBases>
			<MoveSpeed>4.6</MoveSpeed>
			<ArmorRating_Blunt>0.2</ArmorRating_Blunt>
			<ArmorRating_Sharp>0.35</ArmorRating_Sharp>
			<VQE_LifespanYears>5</VQE_LifespanYears>
			<MaxFlightTime>30</MaxFlightTime>
		</statBases>
		<race>
			<thinkTreeMain>VQE_Drone</thinkTreeMain>
			<thinkTreeConstant>VQE_BattleDroneConstant</thinkTreeConstant>
			<baseHealthScale>1.2</baseHealthScale>
			<baseBodySize>0.8</baseBodySize>
			<body>VQE_DroneFlying</body>
			<hasCorpse>true</hasCorpse>
			<lifeStageAges>
				<li>
					<def>MechanoidFullyFormed</def>
					<minAge>0</minAge>
					<soundWounded>VQE_Drone_Medium_Wounded</soundWounded>
					<soundDeath>VQE_Drone_Death</soundDeath>
					<soundCall>VQE_Drone_Medium_Call</soundCall>
				</li>
			</lifeStageAges>
		</race>
		<tools>
			<li>
				<label>shell spike</label>
				<capacities>
					<li>Stab</li>
				</capacities>
				<power>9</power>
				<cooldownTime>2</cooldownTime>
				<linkedBodyPartsGroup>VQE_SpikedShellAttackTool</linkedBodyPartsGroup>
				<ensureLinkedBodyPartsGroupAlwaysUsable>true</ensureLinkedBodyPartsGroupAlwaysUsable>
			</li>
		</tools>
		<butcherProducts>
			<Steel>120</Steel>
			<ComponentIndustrial>3</ComponentIndustrial>
		</butcherProducts>
		<comps>
			<li>
				<compClass>CompSentryDrone</compClass>
			</li>
		</comps>
	</ThingDef>
	<PawnKindDef ParentName="VQE_BaseDroneKind">
		<defName>VQE_HornetDrone</defName>
		<label>hornet drone</label>
		<labelPlural>hornet drones</labelPlural>
		<race>VQE_HornetDrone</race>
		<combatPower>100</combatPower>
		<canOpenAnyDoor>true</canOpenAnyDoor>
		<lifeStages>
			<li>
				<bodyGraphicData>
					<texPath>Things/Drones/Hornet/Hornet</texPath>
					<drawSize>1.45</drawSize>
				</bodyGraphicData>
			</li>
		</lifeStages>
		<canOpenDoors>true</canOpenDoors>
		
	</PawnKindDef>
</Defs>