<BodyDef>
    <defName>VQE_DroneWithSingleWheel</defName>
    <label>drone</label>
    <corePart>
      <def>VQE_DroneChassis</def>
      <height>Middle</height>
      <depth>Outside</depth>
      <groups>
        <li>Torso</li>
      </groups>
      <parts>
        <li>
          <def>VQE_DroneCore</def>
          <coverage>0.05</coverage>
          <depth>Inside</depth>
        </li>
        <li>
          <def>VQE_DroneEye</def>
          <coverage>0.05</coverage>
          <depth>Outside</depth>
        </li>
        <li>
          <def>VQE_DroneAntenna</def>
          <coverage>0.05</coverage>
          <depth>Outside</depth>
          <height>Top</height>
        </li>
        <li>
          <def>VQE_DroneShellSection</def>
          <coverage>0.2</coverage>
          <depth>Outside</depth>
        </li>
        <li>
          <def>VQE_DroneShellSectionWithSpike</def>
          <coverage>0.2</coverage>
          <depth>Outside</depth>
          <groups>
            <li>VQE_SpikedShellAttackTool</li>
          </groups>
        </li>
        <li>
          <def>VQE_DroneWheel</def>
          <customLabel>wheel</customLabel>
          <coverage>0.15</coverage>
          <height>Bottom</height>
        </li>
      </parts>
    </corePart>
  </BodyDef>

