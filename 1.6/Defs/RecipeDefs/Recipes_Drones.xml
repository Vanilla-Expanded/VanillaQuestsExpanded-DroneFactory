<?xml version="1.0" encoding="utf-8" ?>
<Defs>
	<RecipeDef>
		<defName>VQE_DisassembleDrone</defName>
		<label>disassemble drone</label>
		<description>Disassemble a dead drone to reclaim all resources spent to construct it.</description>
		<jobString>Disassembling drone.</jobString>
		<workAmount>600</workAmount>
		<soundWorking>Recipe_ButcherCorpseMechanoid</soundWorking>
		<workSpeedStat>ButcheryMechanoidSpeed</workSpeedStat>
		<workSkill>Crafting</workSkill>
		<efficiencyStat>ButcheryMechanoidEfficiency</efficiencyStat>
		<effectWorking>ButcherMechanoid</effectWorking>
		<uiIconThing>ComponentIndustrial</uiIconThing>
		<recipeUsers>
			<li>VQE_DroneTinkeringBench</li>
		</recipeUsers>
		<ingredients>
			<li>
				<filter>
					<categories>
						<li>VQE_CorpsesDrone</li>
					</categories>
				</filter>
				<count>1</count>
			</li>
		</ingredients>
		<specialProducts>
			<li>Butchery</li>
		</specialProducts>
		<fixedIngredientFilter>
			<categories>
				<li>VQE_CorpsesDrone</li>
				<li MayRequire="Ludeon.RimWorld.Odyssey">CorpsesDrone</li>
			</categories>
		</fixedIngredientFilter>
		<defaultIngredientFilter>
			<categories>
				<li>VQE_CorpsesDrone</li>
				<li MayRequire="Ludeon.RimWorld.Odyssey">CorpsesDrone</li>
			</categories>
			<specialFiltersToDisallow>
				<li MayRequire="Ludeon.RimWorld.Biotech">AllowCorpsesMechFriendly</li>
			</specialFiltersToDisallow>
			<specialFiltersToAllow>
				<li MayRequire="Ludeon.RimWorld.Biotech">AllowCorpsesMechEnemy</li>
			</specialFiltersToAllow>
		</defaultIngredientFilter>
		<displayPriority>0</displayPriority>
	</RecipeDef>
	<RecipeDef>
		<defName>VQE_AssembleBattleDrone</defName>
		<label>Assemble battle drone</label>
		<description>Make a battle drone.</description>
		<jobString>Assembling battle drone.</jobString>
		<workSpeedStat>GeneralLaborSpeed</workSpeedStat>
		<effectWorking>Cook</effectWorking>
		<soundWorking>Recipe_Machining</soundWorking>
		<workAmount>40000</workAmount>
		<unfinishedThingDef>VQE_UnfinishedDrone</unfinishedThingDef>
		<recipeUsers>
			<li>VQE_DroneTinkeringBench</li>
		</recipeUsers>
		<ingredients>
			<li>
				<filter>
					<thingDefs>
						<li>Steel</li>
					</thingDefs>
				</filter>
				<count>100</count>
			</li>
			<li>
				<filter>
					<thingDefs>
						<li>ComponentIndustrial</li>
					</thingDefs>
				</filter>
				<count>4</count>
			</li>
		</ingredients>
		<fixedIngredientFilter>
			<thingDefs>
				<li>Steel</li>
				<li>ComponentIndustrial</li>
			</thingDefs>
		</fixedIngredientFilter>
		<products>
			<VQE_BattleDrone>1</VQE_BattleDrone>
		</products>
		<skillRequirements>
			<Crafting>3</Crafting>
