<?xml version="1.0" encoding="UTF-8"?>
<Defs>
	<ThingDef ParentName="VQED_TrapIEDBase">
		<defName>VQED_DormantBattleDrone_Active</defName>
		<label>dormant battle drone</label>
		<description>An automated battle drone. It continuously patrols an area, looking for intruders. Once an intruder is found, it will relentlessly attack with a small stubgun.\n\nThis drone seems to be in a dormant state.</description>
		<size>(1,1)</size>
		<killedLeavings>
			<ChunkSlagSteel>1</ChunkSlagSteel>
		</killedLeavings>
		<statBases>
			<MaxHitPoints>150</MaxHitPoints>
			<Flammability>0</Flammability>
			<Beauty>-1</Beauty>
		</statBases>
		<graphicData>
			<texPath>Things/Structure/Ancient/DisabledDormantDrones/DisabledDormantDrone_BattleDrone</texPath>
			<graphicClass>Graphic_Random</graphicClass>
			<drawSize>1.5</drawSize>
		</graphicData>
		<thingClass>VanillaQuestsExpandedDroneFactory.Building_DroneTrap</thingClass>
		<modExtensions>
			<li Class="VanillaQuestsExpandedDroneFactory.DroneTrapDetails">
				<droneSpawn>VQE_BattleDrone</droneSpawn>
				<deconstructSound>VQE_Drone_Medium_Call</deconstructSound>
			</li>
		</modExtensions>
	</ThingDef>
	<ThingDef ParentName="VQED_TrapIEDBase">
		<defName>VQED_DormantRaiderDrone_Active</defName>
		<label>dormant raider drone</label>
		<description>An automated drone designed for close-quarters raiding and heavy suppression. Equipped with a high-capacity rattlegun, its slow, heavily armored frame allows it to stand its ground and saturate an area with continuous fire, suppressing enemy positions.\n\nThis drone seems to be in a dormant state.</description>
		<size>(1,1)</size>
		<killedLeavings>
			<ChunkSlagSteel>1</ChunkSlagSteel>
		</killedLeavings>
		<statBases>
			<MaxHitPoints>200</MaxHitPoints>
			<Flammability>0</Flammability>
			<Beauty>-1</Beauty>
		</statBases>
		<graphicData>
			<texPath>Things/Structure/Ancient/DisabledDormantDrones/DisabledDormantDrone_RaiderDrone</texPath>
			<graphicClass>Graphic_Random</graphicClass>
			
		</graphicData>
		<thingClass>VanillaQuestsExpandedDroneFactory.Building_DroneTrap</thingClass>
		<modExtensions>
			<li Class="VanillaQuestsExpandedDroneFactory.DroneTrapDetails">
				<droneSpawn>VQE_RaiderDrone</droneSpawn>
				<deconstructSound>VQE_Drone_Medium_Call</deconstructSound>
			</li>
		</modExtensions>
	</ThingDef>
	<ThingDef ParentName="VQED_TrapIEDBase">
		<defName>VQED_DormantHornetDrone_Active</defName>
		<label>dormant hornet drone</label>
		<description>An automated military drone for close-range defense and combat support. The drone is capable of piercing an enemy repeatedly with a long, hardened stinger. While it doesn’t carry the same paralytic as wasp drones, it’s capable of piercing heavy armor and dealing significant damage, while its heavy-duty armor plating allows it to withstand a lot of damage.\n\nThis drone seems to be in a dormant state.</description>
		<size>(1,1)</size>
		<killedLeavings>
			<ChunkSlagSteel>1</ChunkSlagSteel>
		</killedLeavings>
		<statBases>
			<MaxHitPoints>100</MaxHitPoints>
			<Flammability>0</Flammability>
			<Beauty>-1</Beauty>
		</statBases>
		<graphicData>
			<texPath>Things/Structure/Ancient/DisabledDormantDrones/DisabledDormantDrone_HornetDrone</texPath>
			<graphicClass>Graphic_Random</graphicClass>
			
		</graphicData>
		<thingClass>VanillaQuestsExpandedDroneFactory.Building_DroneTrap</thingClass>
		<modExtensions>
			<li Class="VanillaQuestsExpandedDroneFactory.DroneTrapDetails">
				<droneSpawn>VQE_HornetDrone</droneSpawn>
				<deconstructSound>VQE_Drone_Medium_Call</deconstructSound>
			</li>
		</modExtensions>
	</ThingDef>
	
	<ThingDef ParentName="VQED_DronesBuildingBase">
		<defName>VQE_ImmobilizedTurret</defName>
		<label>immobilized turret</label>
		<description>A broken down mobile turret. The old targeting mechanism still works.</description>
		<thingClass>Building_TurretGun</thingClass>
		<drawerType>MapMeshAndRealTime</drawerType>
		<graphicData>
			<texPath>Things/Structure/Security/ScrappedDroneTurret/ScrappedDroneTurret_Base</texPath>
			<graphicClass>Graphic_Single</graphicClass>
			<drawSize>(3,3)</drawSize>
			<damageData>
				<rect>(0.2,0.2,0.6,0.6)</rect>
			</damageData>
			<shadowData>
				<volume>(0.27,0.25,0.27)</volume>
				<offset>(0,0,0)</offset>
			</shadowData>
		</graphicData>
		<uiIconPath>Things/Structure/Security/ScrappedDroneTurret/ScrappedDroneTurret_MenuIcon</uiIconPath>
		<uiIconScale>0.90</uiIconScale>
		
		<altitudeLayer>Building</altitudeLayer>
		<stealable>false</stealable>
		<rotatable>false</rotatable>
		
		<statBases>
			<MaxHitPoints>200</MaxHitPoints>
			<Flammability>0</Flammability>
			<WorkToBuild>1800</WorkToBuild>
			
			<Beauty>-20</Beauty>
		
			<ShootingAccuracyTurret>0.96</ShootingAccuracyTurret>
		</statBases>
		<tickerType>Normal</tickerType>
		
		<passability>PassThroughOnly</passability>
		<pathCost>50</pathCost>
		<fillPercent>0.4</fillPercent>
		<hasTooltip>true</hasTooltip>
		
		<terrainAffordanceNeeded>Light</terrainAffordanceNeeded>
		<building>
			
			<!-- same as a scavenger -->
			<ai_combatDangerous>true</ai_combatDangerous>
			<turretGunDef>VQE_ImmobilizedTurret_Gun</turretGunDef>
			<turretBurstCooldownTime>5.8</turretBurstCooldownTime>
			<neverBuildable>true</neverBuildable>
		</building>
		<placeWorkers>
			<li>PlaceWorker_TurretTop</li>
			<li>PlaceWorker_ShowTurretRadius</li>
		</placeWorkers>
	</ThingDef>
	<ThingDef ParentName="BaseBullet">
		<defName>VQE_ImmobilizedTurret_Bullet</defName>
		<label>mini-turret bullet</label>
		<graphicData>
			<texPath>Things/Projectile/Bullet_Small</texPath>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<projectile>
			<damageDef>Bullet</damageDef>
			<damageAmountBase>8</damageAmountBase>
			<speed>70</speed>
			<stoppingPower>0.5</stoppingPower>
			<armorPenetrationBase>0.12</armorPenetrationBase>
		</projectile>
	</ThingDef>
	<ThingDef ParentName="BaseWeaponTurret">
		<defName>VQE_ImmobilizedTurret_Gun</defName>
		<label>immobilized turret</label>
		<description>A broken down mobile turret. The old targeting mechanism still works.</description>
		<graphicData>
			<texPath>Things/Structure/Security/ScrappedDroneTurret/ScrappedDroneTurret_Top</texPath>
			<graphicClass>Graphic_Single</graphicClass>
		</graphicData>
		<statBases>
			<AccuracyTouch>0.77</AccuracyTouch>
			<AccuracyShort>0.70</AccuracyShort>
			<AccuracyMedium>0.45</AccuracyMedium>
			<AccuracyLong>0.24</AccuracyLong>
			<RangedWeapon_Cooldown>5.8</RangedWeapon_Cooldown>
			<DeteriorationRate>0</DeteriorationRate>
			<Mass>5</Mass>
			<Flammability>0</Flammability>
		</statBases>
		<verbs>
			<li>
				<verbClass>Verb_Shoot</verbClass>
				<defaultProjectile>VQE_ImmobilizedTurret_Bullet</defaultProjectile>
				<warmupTime>0</warmupTime>
				<range>36.9</range>
				<ticksBetweenBurstShots>22</ticksBetweenBurstShots>
				<burstShotCount>3</burstShotCount>
				<soundCast>GunShotA</soundCast>
				<soundCastTail>GunTail_Light</soundCastTail>
				<muzzleFlashScale>9</muzzleFlashScale>
				
			</li>
		</verbs>
	</ThingDef>
</Defs>