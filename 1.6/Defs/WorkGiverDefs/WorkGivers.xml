<?xml version="1.0" encoding="utf-8" ?>
<Defs>
	<WorkGiverDef>
		<defName>VQE_DoBillsDroneBench</defName>
		<label>fabricate drones</label>
		<giverClass>WorkGiver_DoBill</giverClass>
		<workType>Smithing</workType>
		<priorityInType>50</priorityInType>
		<fixedBillGiverDefs>
			<li>VQE_DroneTinkeringBench</li>
		</fixedBillGiverDefs>
		<verb>fabricate drones at</verb>
		<gerund>fabricating drones at</gerund>
		<requiredCapacities>
			<li>Manipulation</li>
		</requiredCapacities>
		<prioritizeSustains>true</prioritizeSustains>
	</WorkGiverDef>
	<!-- ============= Farming Drones ============= -->
	<WorkGiverDef>
		<defName>VQE_DroneGrowerHarvest</defName>
